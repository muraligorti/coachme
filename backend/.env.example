# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fitos_nexus

# JWT
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-refresh-secret

# Frontend URL (used for OAuth redirect callbacks)
FRONTEND_URL=https://coachme.life

# --- Device OAuth Credentials ---
# Fitbit (https://dev.fitbit.com/apps)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Google Fit (https://console.cloud.google.com - OAuth 2.0 credentials)
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=

# Strava (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Huawei Health (https://developer.huawei.com/consumer/en/service/josp/agc/index.html)
HUAWEI_CLIENT_ID=
HUAWEI_CLIENT_SECRET=
