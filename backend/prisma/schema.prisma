// ═══════════════════════════════════════════════════════════════════════
// FIT:OS NEXUS — PostgreSQL Schema (Prisma ORM)
// 
// Tables: User, CoachProfile, ClientProfile, Subscription, Client,
//         Workout, WorkoutSession, Exercise, Lead, Review, AuditLog,
//         Notification, Booking, Report, MedicalData (encrypted)
// ═══════════════════════════════════════════════════════════════════════

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────

enum Role {
  ADMIN
  COACH
  CLIENT
}

enum SubscriptionTier {
  FREE
  STARTER
  PRO
  ELITE
  PREMIUM  // Client premium tier
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum SessionType {
  ONLINE
  IN_PERSON
  HYBRID
}

// ─── USER (Core Auth) ────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String    // bcrypt hashed
  role            Role      @default(CLIENT)
  emailVerified   Boolean   @default(false)
  verifyToken     String?
  resetToken      String?
  resetExpires    DateTime?
  lastLogin       DateTime?
  loginAttempts   Int       @default(0)
  lockedUntil     DateTime?
  twoFactorSecret String?
  twoFactorEnabled Boolean  @default(false)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  coachProfile    CoachProfile?
  clientProfile   ClientProfile?
  subscription    Subscription?
  sessions        Session[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  sentMessages    Message[]     @relation("SentMessages")
  receivedMessages Message[]    @relation("ReceivedMessages")

  @@index([email])
  @@index([role])
  @@index([isActive])
}

// ─── SESSION (JWT Token Management) ──────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([refreshToken])
  @@index([expiresAt])
}

// ─── COACH PROFILE ───────────────────────────────────────────────────

model CoachProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName       String
  phone             String?
  avatar            String?   // S3/R2 URL
  bio               String?   @db.Text
  country           String
  city              String
  latitude          Float?
  longitude         Float?
  specializations   String[]  // Array of specialization strings
  certifications    String[]
  languages         String[]
  experienceYears   Int       @default(0)
  pricePerSession   Int       @default(30) // USD cents would be better for production
  currency          String    @default("USD")
  sessionTypes      SessionType[] @default([ONLINE])
  instagram         String?
  website           String?
  gymName           String?
  verified          Boolean   @default(false)
  verifiedAt        DateTime?
  featured          Boolean   @default(false)
  rating            Float     @default(0)
  reviewCount       Int       @default(0)
  totalClients      Int       @default(0)
  totalSessions     Int       @default(0)
  isOnline          Boolean   @default(false)
  lastOnline        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  clients           ClientCoach[]
  bookings          Booking[]
  workoutPlans      WorkoutPlan[]
  reviews           Review[]
  leads             Lead[]
  reports           Report[]     @relation("CoachReports")

  @@index([country, city])
  @@index([specializations])
  @@index([rating])
  @@index([verified])
  @@index([pricePerSession])
}

// ─── CLIENT PROFILE ──────────────────────────────────────────────────

model ClientProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName     String
  age             Int?
  gender          String?
  heightCm        Float?
  weightKg        Float?
  country         String?
  city            String?
  fitnessGoals    String[]
  experience      String?   @default("beginner")
  avatar          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  coaches         ClientCoach[]
  medicalData     MedicalData?
  workoutSessions WorkoutSession[]
  bookings        Booking[]
  reviews         Review[]

  @@index([country, city])
  @@index([fitnessGoals])
}

// ─── CLIENT-COACH RELATIONSHIP ───────────────────────────────────────

model ClientCoach {
  id          String   @id @default(cuid())
  clientId    String
  coachId     String
  client      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  coach       CoachProfile  @relation(fields: [coachId], references: [id], onDelete: Cascade)
  status      String   @default("active") // active, paused, ended
  startDate   DateTime @default(now())
  endDate     DateTime?
  notes       String?  @db.Text

  @@unique([clientId, coachId])
  @@index([coachId])
  @@index([status])
}

// ─── MEDICAL DATA (Encrypted at application level) ───────────────────

model MedicalData {
  id              String   @id @default(cuid())
  clientId        String   @unique
  client          ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // These fields are AES-256 encrypted before storage
  conditionsEnc   String?  @db.Text  // Encrypted JSON
  medicationsEnc  String?  @db.Text
  injuriesEnc     String?  @db.Text
  surgeriesEnc    String?  @db.Text
  allergiesEnc    String?  @db.Text
  notesEnc        String?  @db.Text
  encryptionVersion Int    @default(1)
  updatedAt       DateTime @updatedAt
}

// ─── SUBSCRIPTION ────────────────────────────────────────────────────

model Subscription {
  id              String           @id @default(cuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier            SubscriptionTier @default(FREE)
  stripeCustomerId String?
  stripeSubId     String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean       @default(false)
  maxClients      Int              @default(5)
  features        Json?            // Feature flags JSON
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tier])
  @@index([stripeCustomerId])
}

// ─── WORKOUT PLANS ───────────────────────────────────────────────────

model WorkoutPlan {
  id              String    @id @default(cuid())
  coachId         String
  coach           CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name            String
  description     String?   @db.Text
  intensity       String    @default("moderate")
  durationWeeks   Int       @default(4)
  focus           String?
  exercises       Json      // Array of exercise objects
  weeklySchedule  Json?     // Weekly plan structure
  aiGenerated     Boolean   @default(false)
  isTemplate      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions        WorkoutSession[]

  @@index([coachId])
  @@index([isTemplate])
}

// ─── WORKOUT SESSIONS (Individual workouts performed) ────────────────

model WorkoutSession {
  id              String    @id @default(cuid())
  clientId        String
  client          ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planId          String?
  plan            WorkoutPlan? @relation(fields: [planId], references: [id])
  exerciseName    String
  durationSeconds Int
  caloriesBurned  Int       @default(0)
  formScore       Float?
  reps            Int       @default(0)
  sets            Int       @default(0)
  intensity       String?
  heartRateAvg    Int?
  heartRateMax    Int?
  fatigueLevel    Float?
  cameraUsed      Boolean   @default(false)
  aiCoachingUsed  Boolean   @default(false)
  xpEarned        Int       @default(0)
  notes           String?   @db.Text
  completedAt     DateTime  @default(now())

  @@index([clientId])
  @@index([completedAt])
  @@index([planId])
}

// ─── BOOKINGS ────────────────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  clientId        String
  coachId         String
  client          ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  coach           CoachProfile  @relation(fields: [coachId], references: [id], onDelete: Cascade)
  scheduledAt     DateTime
  durationMinutes Int           @default(60)
  sessionType     SessionType   @default(ONLINE)
  status          BookingStatus @default(PENDING)
  price           Int           @default(0)
  currency        String        @default("USD")
  meetingLink     String?
  notes           String?       @db.Text
  cancelReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([coachId, scheduledAt])
  @@index([clientId, scheduledAt])
  @@index([status])
}

// ─── LEADS (AI-scored potential clients) ─────────────────────────────

model Lead {
  id              String     @id @default(cuid())
  coachId         String
  coach           CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name            String
  email           String?
  phone           String?
  location        String?
  fitnessGoal     String?
  intentSignal    String?    // What triggered the lead
  matchScore      Int        @default(0) // 0-100 AI-computed
  status          LeadStatus @default(NEW)
  source          String?    // "search", "referral", "ai_match"
  notes           String?    @db.Text
  contactedAt     DateTime?
  convertedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([coachId])
  @@index([matchScore])
  @@index([status])
}

// ─── REVIEWS ─────────────────────────────────────────────────────────

model Review {
  id              String    @id @default(cuid())
  clientId        String
  coachId         String
  client          ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  coach           CoachProfile  @relation(fields: [coachId], references: [id], onDelete: Cascade)
  rating          Int       // 1-5
  comment         String?   @db.Text
  isPublic        Boolean   @default(true)
  response        String?   @db.Text // Coach can respond
  createdAt       DateTime  @default(now())

  @@unique([clientId, coachId]) // One review per coach per client
  @@index([coachId])
  @@index([rating])
}

// ─── REPORTS (Analytics) ─────────────────────────────────────────────

model Report {
  id              String   @id @default(cuid())
  coachId         String
  coach           CoachProfile @relation("CoachReports", fields: [coachId], references: [id], onDelete: Cascade)
  type            String   // "weekly", "monthly", "quarterly", "annual"
  period          String   // "2024-W48", "2024-12", "2024-Q4"
  data            Json     // Report data: revenue, clients, sessions, etc.
  generatedAt     DateTime @default(now())

  @@index([coachId, type, period])
  @@unique([coachId, type, period])
}

// ─── MESSAGES ────────────────────────────────────────────────────────

model Message {
  id              String   @id @default(cuid())
  senderId        String
  receiverId      String
  sender          User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver        User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content         String   @db.Text
  read            Boolean  @default(false)
  readAt          DateTime?
  createdAt       DateTime @default(now())

  @@index([receiverId, read])
  @@index([senderId])
  @@index([createdAt])
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────

model Notification {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String   // "booking", "review", "lead", "system", "workout"
  title           String
  body            String
  data            Json?    // Additional payload
  read            Boolean  @default(false)
  readAt          DateTime?
  createdAt       DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

// ─── AUDIT LOG (Security tracking) ───────────────────────────────────

model AuditLog {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action          String   // "login", "logout", "create_client", "update_plan", etc.
  resource        String?  // "user", "client", "workout", etc.
  resourceId      String?
  ipAddress       String?
  userAgent       String?
  details         Json?    // Additional context
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resource, resourceId])
}
