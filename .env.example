# ═══ FIT:OS NEXUS — Environment Variables ═══

# Database
DATABASE_URL=postgresql://nexus:nexus_secure_2024@localhost:5432/nexus
DB_PASSWORD=nexus_secure_2024

# Redis
REDIS_URL=redis://:nexus_redis_2024@localhost:6379
REDIS_PASSWORD=nexus_redis_2024

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_64_char_random_hex_string_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_char_random_hex_openssl_rand_hex_32

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-api-your-key-here

# Encryption (for medical data — generate with: openssl rand -hex 16)
ENCRYPTION_KEY=CHANGE_ME_32_byte_hex_key

# Server
NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://your-domain.com
LOG_LEVEL=info

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# Email (SendGrid/Resend)
EMAIL_API_KEY=your_email_key
EMAIL_FROM=noreply@fitos-nexus.com
